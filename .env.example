# ============================================================
# FreshCart — Environment Variables
# Copy to .env.local (local dev) or set in your deployment
# ============================================================

# ── MongoDB ──────────────────────────────────────────────────
# Docker Compose (no auth, service name resolves inside Docker)
MONGO_URI=mongodb://mongodb:27017/freshcart

# Local dev with Docker MongoDB (auth enabled on localhost)
# MONGO_URI=mongodb://freshcart_admin:freshcart_secret@localhost:27017/freshcart?authSource=admin

# MongoDB Atlas
# MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/freshcart

# ── NextAuth.js ───────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── App ───────────────────────────────────────────────────────
# Note: NEXT_PUBLIC_* vars are baked in at build time.
# Rebuild the Docker image if you change these.
NEXT_PUBLIC_APP_NAME=FreshCart
NEXT_PUBLIC_APP_URL=http://localhost:3000
